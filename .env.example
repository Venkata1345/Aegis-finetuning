# Copy to .env locally, or paste into a Colab cell as `os.environ[...] = ...`.
# Never commit the real .env.

# Hugging Face — required for downloading datasets and pushing the trained LoRA adapter.
HF_TOKEN=

# Weights & Biases — required for training run tracking. Free tier is enough.
WANDB_API_KEY=

# Baselines — required for `aegis eval` and `aegis compare` to call the
# commercial APIs. Eval will skip a baseline cleanly if its key is missing.
OPENAI_API_KEY=
GOOGLE_API_KEY=

# HF Hub repo of the trained Aegis LoRA adapter (used by the `aegis` predictor)
AEGIS_ADAPTER_REPO=
